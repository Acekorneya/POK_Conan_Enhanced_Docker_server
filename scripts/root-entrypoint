#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=scripts/lib.sh
source "$SCRIPT_DIR/lib.sh"

require_uint PUID "${PUID:-1000}"
require_uint PGID "${PGID:-1000}"

export PUID="${PUID:-1000}"
export PGID="${PGID:-1000}"
export SERVER_DIR="${SERVER_DIR:-/data/server}"
export STEAM_DIR="${STEAM_DIR:-/data/steam}"
export BACKUP_DIR="${BACKUP_DIR:-/data/backups}"
export STEAMCMD_DIR="${STEAMCMD_DIR:-/opt/steamcmd}"

existing_group="$(getent group "$PGID" | cut -d: -f1 || true)"
if [[ -n "$existing_group" && "$existing_group" != "pokuser" ]]; then
  primary_group="$PGID"
elif ! getent group pokuser >/dev/null; then
  groupadd --gid "$PGID" pokuser
  primary_group="$PGID"
else
  current_gid="$(getent group pokuser | cut -d: -f3)"
  if [[ "$current_gid" != "$PGID" ]]; then
    groupmod --gid "$PGID" pokuser
  fi
  primary_group="$PGID"
fi

if ! id pokuser >/dev/null 2>&1; then
  useradd --create-home --shell /bin/bash --uid "$PUID" --gid "$primary_group" pokuser
else
  current_uid="$(id -u pokuser)"
  current_primary_gid="$(id -g pokuser)"
  if [[ "$current_uid" != "$PUID" || "$current_primary_gid" != "$primary_group" ]]; then
    usermod --uid "$PUID" --gid "$primary_group" --home /home/pokuser pokuser
  fi
fi

mkdir -p "$SERVER_DIR" "$STEAM_DIR" "$BACKUP_DIR" "$STEAMCMD_DIR" /home/pokuser
chown -R "$PUID:$PGID" "$SERVER_DIR" "$STEAM_DIR" "$BACKUP_DIR" "$STEAMCMD_DIR" /home/pokuser
chmod -R u+rwX,go+rX "$STEAMCMD_DIR"

export HOME=/home/pokuser
cd "$SERVER_DIR"

exec setpriv --reuid="$PUID" --regid="$PGID" --init-groups /usr/local/bin/server-command.sh "$@"
