# Host user ID that should own files created in ./data.
# Find it on Linux with: id -u
# Example: PUID=1000
PUID=1000

# Host group ID that should own files created in ./data.
# Find it on Linux with: id -g
# Example: PGID=1000
PGID=1000

# Container timezone in IANA format.
# Examples: TZ=America/Los_Angeles, TZ=America/New_York, TZ=UTC
# List valid timezones on Linux with: timedatectl list-timezones
TZ=UTC

# Public server name shown in the Conan server browser.
SERVER_NAME=Conan Exiles Enhanced Server

# Optional password required for players to join the server.
# Leave empty for a public server with no join password.
SERVER_PASSWORD=

# Admin password used for in-game admin access.
# Change this before first start; the container rejects the example value.
ADMIN_PASSWORD=change-me

# Maximum number of connected players.
MAX_PLAYERS=40

# Main UDP game port exposed to players.
SERVER_PORT=7777

# Extra UDP peer/raw port used by the server. Usually SERVER_PORT + 1.
RAW_UDP_PORT=7778

# Steam query UDP port used by the server browser.
QUERY_PORT=27015

# IP address the server binds inside the container.
# Use 0.0.0.0 unless you have a specific networking reason to change it.
MULTIHOME=0.0.0.0

# Enables RCON inside the container for health checks and graceful shutdown saves.
RCON_ENABLED=true

# RCON password. Change this before first start; the container rejects the example value.
RCON_PASSWORD=change-me-rcon

# RCON TCP port inside the container. Not exposed to the host unless using docker-compose.rcon.yml.
RCON_PORT=25575

# Optional message of the day shown to players when they join the server.
# Leave empty to disable.
SERVER_MESSAGE_OF_THE_DAY=

# false means the Docker healthcheck only requires the Conan server process.
# Set true if you want Docker health to fail when RCON does not answer.
HEALTHCHECK_REQUIRE_RCON=false

# true lets the supervisor restart the Conan process when repeated health checks fail.
SERVER_WATCHDOG_ENABLED=true

# Seconds between watchdog health checks after startup grace has passed.
SERVER_WATCHDOG_INTERVAL_SECONDS=60

# Number of consecutive failed checks before the watchdog restarts the Conan process.
SERVER_WATCHDOG_FAILURE_THRESHOLD=3

# Seconds to wait after each launch before watchdog checks begin.
SERVER_WATCHDOG_STARTUP_GRACE_SECONDS=600

# Extra grace seconds after a watchdog recovery restart before checking again.
SERVER_WATCHDOG_RESTART_COOLDOWN_SECONDS=300

# Max watchdog recovery restarts before exiting so Docker can recreate the container. Set 0 for unlimited.
SERVER_WATCHDOG_MAX_RESTARTS=3

# Seconds to wait after SIGTERM for old Conan processes to exit before the supervisor exits non-zero.
SERVER_STOP_GRACE_SECONDS=10

# true checks for Steam server updates every time the container starts.
# It also enables the periodic in-container update monitor while the server is running.
AUTO_UPDATE=true

# Hours between automatic update checks while the server is running. Valid range: 1-24.
AUTO_UPDATE_CHECK_INTERVAL_HOURS=6

# Minutes of player warning before an automatic update restart.
AUTO_UPDATE_RESTART_NOTICE_MINUTES=30

# true enables daily automated game-server restarts.
DAILY_RESTART_ENABLED=false

# Daily restart time in HH:MM format, interpreted in the configured TZ.
DAILY_RESTART_TIME=02:00

# Steam beta branch to install. Keep public for the normal server branch.
STEAM_BRANCH=public

# true asks SteamCMD to validate server files during update. Slower but useful after file issues.
STEAM_VALIDATE=false

# Ordered Steam Workshop IDs. Separate IDs with commas or spaces.
# Example: MOD_IDS=123456789,987654321
MOD_IDS=

# true enables scheduled backups and optional shutdown backups.
BACKUP_ENABLED=true

# Minutes between scheduled backups while the server is running.
BACKUP_INTERVAL_MINUTES=60

# Number of newest backup archives to keep. Older backups are deleted.
# Set to 0 to disable retention cleanup.
BACKUP_RETENTION_COUNT=30

# true creates one final backup when the container receives a normal stop/restart signal.
BACKUP_ON_STOP=true

# Seconds to wait after RCON shutdown for save-file timestamp activity before continuing shutdown.
SAVE_VERIFY_TIMEOUT=60

# Common Conan settings.
# true enables player-vs-player damage; false makes the server PvE.
PVP_ENABLED=true
# Server browser community filter. Valid values:
# 0=Purist, 1=Relaxed, 2=HardCore, 3=RolePlaying, 4=Experimental.
COMMUNITY=0
# Server browser region filter. Valid values:
# 0=Europe, 1=North America, 2=Asia, 3=Australia, 4=South America, 5=Japan.
SERVER_REGION=0
# In-game voice chat. Valid values: 0=disabled, 1=enabled.
SERVER_VOICE_CHAT=0
# Enables BattlEye anti-cheat.
ENABLE_BATTLEYE=true
# true lets players damage/destroy player-owned buildings and structures.
CAN_DAMAGE_PLAYER_OWNED_STRUCTURES=false
# Maximum number of players allowed in one clan.
CLAN_MAX_SIZE=10
# true allows building placement outside normal placement restrictions.
ALLOW_BUILDING_ANYWHERE=false
# true enables decay/abandonment cleanup for player buildings.
BUILDING_ABANDONMENT_ENABLED=true
# 1 drops equipped items when a player dies; 0 keeps them.
DROP_EQUIPMENT_ON_DEATH=1
# 1 drops backpack/inventory items when a player dies; 0 keeps them.
DROP_BACKPACK_ON_DEATH=1
# true lets anyone loot a dead player's corpse; false restricts corpse loot to the owner.
EVERYBODY_CAN_LOOT_CORPSE=true
# true allows avatars/god summons; false disables them.
AVATAR_ENABLED=true
# Nudity limit. Valid values: 0=none, 1=partial, 2=full.
MAX_NUDITY=0
# Resource gathering multiplier. 2.0 means roughly double harvest yield.
HARVEST_AMOUNT_MULTIPLIER=1.0
# Overall player XP multiplier for all XP sources.
XP_RATE_MULTIPLIER=1.0
# XP multiplier for killing NPCs, creatures, or players.
PLAYER_XP_KILL_MULTIPLIER=1.0
# Passive survival/time XP multiplier.
PLAYER_XP_TIME_MULTIPLIER=1.0
# Crafting XP multiplier.
PLAYER_XP_CRAFT_MULTIPLIER=1.0
# Harvesting XP multiplier.
PLAYER_XP_HARVEST_MULTIPLIER=1.0
# Full day/night cycle speed. Higher values make a full day pass faster.
DAY_CYCLE_SPEED_SCALE=1.0
# Daylight speed only. Higher values make daytime pass faster.
DAY_TIME_SPEED_SCALE=1.0
# Night speed only. Higher values make nighttime pass faster.
NIGHT_TIME_SPEED_SCALE=1.0
# Player health regeneration speed multiplier.
PLAYER_HEALTH_REGEN_SPEED_SCALE=1.0
# Sprint stamina cost multiplier. Lower values make sprinting cheaper.
PLAYER_STAMINA_COST_SPRINT_MULTIPLIER=1.0
# General stamina cost multiplier for player actions.
PLAYER_STAMINA_COST_MULTIPLIER=1.0
# NPC respawn speed multiplier. Lower values make NPCs respawn faster.
NPC_RESPAWN_MULTIPLIER=1.0
# Thrall/pet conversion speed multiplier. Lower values finish conversion faster.
THRALL_CONVERSION_MULTIPLIER=0.5
# Crafting material cost multiplier. Lower values make crafting cheaper.
CRAFTING_COST_MULTIPLIER=1.0
# Fuel burn time multiplier. Higher values make fuel last longer.
FUEL_BURN_TIME_MULTIPLIER=1.0
# Item spoil rate multiplier. Lower values make food/items spoil slower.
ITEM_SPOIL_RATE_SCALE=1.0

# Optional local-time PvP schedule. Leave empty for unrestricted PvP.
# Days accept Monday-Sunday plus shortcuts: weekdays, weekends, all.
# Times are local to TZ and converted to UTC for ServerSettings.ini.
PVP_TIME_DAYS=
PVP_TIME_START=
PVP_TIME_END=

# Optional local-time building damage raid window.
# Example: weekends 11:00-23:00 in TZ=America/Los_Angeles.
PVP_BUILDING_DAMAGE_DAYS=
PVP_BUILDING_DAMAGE_START=
PVP_BUILDING_DAMAGE_END=

# Optional local-time avatar summoning window.
# Conan supports weekday/weekend avatar windows, not individual day toggles.
AVATAR_SUMMONING_DAYS=
AVATAR_SUMMONING_START=
AVATAR_SUMMONING_END=

# Advanced ServerSettings.ini overrides.
# Add any supported raw ServerSettings.ini key here and it will be written directly.
# Examples:
# AvatarLifetime=600
# MaxAllowedPing=300
# BuildingPickupEnabled=False
