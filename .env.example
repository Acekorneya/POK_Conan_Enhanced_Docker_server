# Linux user/group used for host volume ownership and the game process.
PUID=1000
PGID=1000
TZ=UTC

# Server identity and access.
SERVER_NAME=Conan Exiles Enhanced Server
SERVER_PASSWORD=
ADMIN_PASSWORD=change-me
MAX_PLAYERS=40

# Network ports.
SERVER_PORT=7777
RAW_UDP_PORT=7778
QUERY_PORT=27015
MULTIHOME=0.0.0.0

# RCON is used internally for health checks and graceful shutdown saves.
RCON_ENABLED=true
RCON_PASSWORD=change-me-rcon
RCON_PORT=25575

# Steam update behavior.
AUTO_UPDATE=true
STEAM_BRANCH=public
STEAM_VALIDATE=false

# Ordered Steam Workshop IDs. Separate IDs with commas or spaces.
MOD_IDS=

# Backups include saves, config, modlist, and metadata.
BACKUP_ENABLED=true
BACKUP_INTERVAL_MINUTES=60
BACKUP_RETENTION_COUNT=30
BACKUP_ON_STOP=true
SAVE_VERIFY_TIMEOUT=60

# Common Conan settings.
PVP_ENABLED=true
COMMUNITY=0
SERVER_REGION=0
SERVER_VOICE_CHAT=0
ENABLE_BATTLEYE=true
CAN_DAMAGE_PLAYER_OWNED_STRUCTURES=false
CLAN_MAX_SIZE=10
ALLOW_BUILDING_ANYWHERE=false
BUILDING_ABANDONMENT_ENABLED=true
DROP_EQUIPMENT_ON_DEATH=true
DROP_BACKPACK_ON_DEATH=true
AVATAR_ENABLED=true
HARVEST_AMOUNT_MULTIPLIER=1.0
XP_RATE_MULTIPLIER=1.0
PLAYER_XP_KILL_MULTIPLIER=1.0
PLAYER_XP_TIME_MULTIPLIER=1.0
PLAYER_XP_CRAFT_MULTIPLIER=1.0
PLAYER_XP_HARVEST_MULTIPLIER=1.0
DAY_CYCLE_SPEED_SCALE=1.0
DAY_TIME_SPEED_SCALE=1.0
NIGHT_TIME_SPEED_SCALE=1.0
PLAYER_HEALTH_REGEN_SPEED_SCALE=1.0
PLAYER_STAMINA_COST_SPRINT_MULTIPLIER=1.0
PLAYER_STAMINA_COST_MULTIPLIER=1.0
NPC_RESPAWN_MULTIPLIER=1.0
THRALL_CONVERSION_MULTIPLIER=1.0
CRAFTING_COST_MULTIPLIER=1.0
FUEL_BURN_TIME_MULTIPLIER=1.0
ITEM_SPOIL_RATE_SCALE=1.0

